{
    "version": 6,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },

        {
            "name": "cppcheck",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_CXX_CPPCHECK": "cppcheck;--inline-suppr;--std=c++20;--enable=all;--suppressions-list=${sourceDir}/cppcheck.supp;--suppress=*:*/tests/*"
            }
        },

        {
            "name": "clang-tidy",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_CXX_CLANG_TIDY": "clang-tidy;-header-filter=${sourceDir}/src/.*;-checks=-*,bugprone-*,concurrency-*,performance-*,-macro*,-bugprone-exception-escape;-warnings-as-errors=*;-extra-arg=-std=c++20"
            }
        },

        {
            "name": "debug",
            "displayName": "Debug",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },

        {
            "name": "release",
            "displayName": "Release",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },

        {
            "name": "lint",
            "displayName": "Debug + clang-tidy + cppcheck",
            "inherits": [
                "debug",
                "clang-tidy",
                "cppcheck"
            ]
        },

        {
            "name": "coverage",
            "displayName": "Coverage",
            "inherits": "debug",
            "cacheVariables": {
                "ITO_ENABLE_COVERAGE": "ON"
            }
        },

        {
            "name": "sanitize-asan",
            "displayName": "ASan",
            "inherits": "debug",
            "cacheVariables": {
                "ITO_ENABLE_ASAN": "ON"
            }
        },

        {
            "name": "sanitize-tsan",
            "displayName": "TSan",
            "inherits": "debug",
            "cacheVariables": {
                "ITO_ENABLE_TSAN": "ON"
            }
        },

        {
            "name": "sanitize-lsan",
            "displayName": "LSan",
            "inherits": "debug",
            "cacheVariables": {
                "ITO_ENABLE_LSAN": "ON"
            }
        },

        {
            "name": "sanitize-msan",
            "displayName": "MSan",
            "inherits": "debug",
            "cacheVariables": {
                "ITO_ENABLE_MSAN": "ON"
            }
        },

        {
            "name": "sanitize-ubsan",
            "displayName": "UBSan",
            "inherits": "debug",
            "cacheVariables": {
                "ITO_ENABLE_UBSAN": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name" : "build",
            "jobs" : 20,
            "configurePreset" : "base"
        }  
    ],
    "testPresets": [
        {
            "name": "tests",
            "output": { "outputOnFailure": true },
            "execution": { "noTestsAction": "error" }, "configurePreset": "base"
        },
        {
            "name": "sanitize",
            "inherits" : ["tests"],
            "environment": {
                "ASAN_OPTIONS": "strict_string_checks=1:detect_stack_use_after_return=1:check_initialization_order=1:strict_init_order=1:detect_leaks=1",
                "UBSAN_OPTIONS": "print_stacktrace=1",
                "TSAN_OPTIONS": "second_deadlock_stack=1"
            }
        }
    ]
}
